{
  "name": "Conversation",
  "type": "object",
  "properties": {
    "title": {
      "type": "string",
      "description": "Short title of the conversation"
    },
    "messages": {
      "type": "array",
      "description": "Chat messages",
      "items": {
        "type": "object",
        "properties": {
          "role": {
            "type": "string",
            "enum": ["user", "assistant"]
          },
          "content": {
            "type": "string"
          }
        }
      },
      "default": []
    }
  },
  "required": ["title"]
}